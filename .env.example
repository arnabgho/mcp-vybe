# Required: Replicate API token for AI model access
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Optional: MCP transport mode
MCP_TRANSPORT=preferred_mode

# ===== OAuth 2.0 Authentication Settings =====

# Enable OAuth authentication (true/false)
ENABLE_OAUTH=false

# JWT Configuration (required if OAuth is enabled)
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=30

# Session secret (defaults to JWT_SECRET_KEY if not set)
# SESSION_SECRET_KEY=your_session_secret_key_here

# OAuth redirect base URL (your server's public URL)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# Google OAuth (optional)
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth (optional)
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===== API Key Authentication (optional fallback) =====

# Enable API key authentication (true/false)
ENABLE_API_KEY_AUTH=false

# API key for authentication (required if ENABLE_API_KEY_AUTH=true)
# Generate a strong key: openssl rand -hex 32
MCP_API_KEY=your_secure_api_key_here

# ===== Server Configuration =====

# Optional: Server configuration (used for deployment)
# PORT=8000
# HOST=0.0.0.0

# HTTPS only mode for production (affects session cookies)
# HTTPS_ONLY=false

# Optional: Timeout settings
# REPLICATE_POLL_INTERVAL=5
# REPLICATE_TIMEOUT=600